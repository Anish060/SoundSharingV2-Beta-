{
  "name": "@sshare/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "eas:build:dev": "eas build --profile development --platform android",
    "eas:build:preview": "eas build --profile preview --platform android",
    "eas:update:dev": "eas update --branch development --message \"dev update\"",
    "eas:update:preview": "eas update --branch preview --message \"preview update\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"(mobile) no tests yet\" && exit 0",
    "build": "echo \"(mobile) build handled by EAS\" && exit 0"
  },
  "dependencies": {
    "@babel/runtime": "^8.0.0",
    "@config-plugins/react-native-webrtc": "^9.0.0",
    "@sshare/shared": "workspace:*",
    "expo": "~51.0.28",
    "expo-status-bar": "~1.12.1",
    "expo-camera": "~15.0.13",
    "expo-dev-client": "~4.0.26",
    "expo-updates": "~0.25.27",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-webrtc": "^124.0.4",
    "socket.io-client": "^4.8.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "typescript": "^5.5.4"
  }
}
